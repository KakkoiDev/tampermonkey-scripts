#!/bin/sh
# Auto-bump @version on changed userscripts.
files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.user\.js$')
if [ -n "$files" ]; then
    node tools/bump-version.mjs $files || exit 1
    git add $files
fi

# Regenerate the README scripts table when scripts or the manifest change,
# so the table can never drift from greasyfork.json.
if git diff --cached --name-only --diff-filter=ACMR | grep -qE '\.user\.js$|^greasyfork\.json$'; then
    node tools/gen-readme.mjs || exit 1
    git add README.md
fi

# Regenerate companion Chrome extensions from their source userscript, so the extension .js
# and manifest version can never drift from the .user.js (the single source of truth).
if git diff --cached --name-only --diff-filter=ACMR | grep -qE '\.user\.js$|extensions/.*/source\.json$'; then
    gen=$(node tools/build-extensions.mjs) || exit 1
    if [ -n "$gen" ]; then git add $gen; fi
fi
